# Supabase — proyecto en https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SOLO server-side, NUNCA con NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Culqi — pasarela de pagos Perú (https://culqi.com)
# Public key → usada en el frontend para tokenizar tarjetas
NEXT_PUBLIC_CULQI_PUBLIC_KEY=
# Secret key → SOLO server-side, NUNCA con NEXT_PUBLIC_
CULQI_SECRET_KEY=

# WhatsApp — número en formato internacional sin + (e.g. 51980792770)
NEXT_PUBLIC_WA_NUMBER=
